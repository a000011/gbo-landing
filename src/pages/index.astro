---
import Layout from '../layouts/Layout.astro';

const localBusinessSchema = {
	'@context': 'https://schema.org',
	'@type': 'AutoRepair',
	name: 'Gas Trek',
	image: '/favicon.svg',
	description: 'Установка, настройка и обслуживание ГБО с гарантией в Тольятти.',
		telephone: '+7-917-810-23-41',
	address: {
		'@type': 'PostalAddress',
		addressLocality: 'Тольятти',
		streetAddress: 'ул. Ларина 145',
		addressCountry: 'RU'
	},
	openingHours: 'Mo-Fr 09:00-19:00, Sa 09:00-13:00',
	areaServed: 'Тольятти',
	priceRange: '31000 RUB+'
};
---

<Layout title="Gas Trek - Установка и обслуживание ГБО" description="Установка, настройка и сервис ГБО с гарантией. Работаем с пропаном и метаном, подбираем комплект под ваш автомобиль.">
