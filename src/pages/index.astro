							<img src="/VK_Logo.svg" alt="ВКонтакте" width="28" height="28" />
						</a>
					</div>
				</div>
				<div class="map-embed" aria-label="Карта проезда Gas Trek">
					<script type="text/javascript" charset="utf-8" async src="https://api-maps.yandex.ru/services/constructor/1.0/js/?um=constructor%3A6d4cb011193cb9eb67ecb58266047f6108c373a3b02b9d75c3128096b7b51991&amp;width=500&amp;height=400&amp;lang=en_FR&amp;scroll=true"></script>
