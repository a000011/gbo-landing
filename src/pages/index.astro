	<script is:inline>
		const items = document.querySelectorAll('.reveal');
		items.forEach((item) => item.classList.add('is-visible'));

		const carousels = document.querySelectorAll('[data-carousel]');
		carousels.forEach((carousel) => {
			const frame = carousel.querySelector('.carousel-frame');
			const track = carousel.querySelector('[data-track]');
			const prev = carousel.querySelector('[data-prev]');
			const next = carousel.querySelector('[data-next]');
			const dots = Array.from(carousel.querySelectorAll('[data-dot]'));
			if (!frame || !track || !prev || !next || dots.length === 0) return;

			const slides = Array.from(track.children);
			let index = 0;
			let touchStartX = 0;
			let touchStartY = 0;
			const swipeThreshold = 45;

			const render = () => {
				track.style.transform = `translateX(-${index * 100}%)`;
				dots.forEach((dot, i) => {
					dot.classList.toggle('is-active', i === index);
				});
			};

			const prevSlide = () => {
				index = index === 0 ? slides.length - 1 : index - 1;
				render();
			};

			const nextSlide = () => {
				index = index === slides.length - 1 ? 0 : index + 1;
				render();
			};

			prev.addEventListener('click', () => {
				prevSlide();
			});

			next.addEventListener('click', () => {
				nextSlide();
			});

			dots.forEach((dot, i) => {
				dot.addEventListener('click', () => {
					index = i;
					render();
				});
			});

			frame.addEventListener('touchstart', (event) => {
				const touch = event.changedTouches[0];
				touchStartX = touch.clientX;
				touchStartY = touch.clientY;
			}, { passive: true });

			frame.addEventListener('touchend', (event) => {
				const touch = event.changedTouches[0];
				const deltaX = touch.clientX - touchStartX;
				const deltaY = touch.clientY - touchStartY;
				if (Math.abs(deltaX) < swipeThreshold || Math.abs(deltaX) < Math.abs(deltaY)) return;
				if (deltaX < 0) {
					nextSlide();
				} else {
					prevSlide();
				}
			}, { passive: true });
		});

		const stretchMap = (embed) => {
			const elements = embed.querySelectorAll('div, iframe, ymaps');
			elements.forEach((element) => {
				element.style.setProperty('width', '100%', 'important');
				element.style.setProperty('max-width', '100%', 'important');
			});
		};

		document.querySelectorAll('.map-embed').forEach((embed) => {
			const observer = new MutationObserver(() => stretchMap(embed));
			observer.observe(embed, { childList: true, subtree: true });
			stretchMap(embed);
		});
	</script>
</Layout>

<style>
	:global(:root) {
		--bg: #edf2f6;
		--bg-soft: #e2e9f0;
		--paper: #f8fbfd;
		--ink: #17212b;
		--muted: #516171;
		--accent: #2f6f96;
		--line: #cad4de;
		--shadow: 0 10px 40px rgba(27, 35, 41, 0.08);
	}

	main {
		background: radial-gradient(circle at 10% -10%, #e5eff8 0%, transparent 50%),
			radial-gradient(circle at 90% -20%, #d9e6f1 0%, transparent 42%),
			var(--bg);
		color: var(--ink);
	}

	.container {
		width: min(1120px, calc(100% - 2.2rem));
		margin: 0 auto;
	}

	.hero {
		position: relative;
		padding: clamp(3.5rem, 6vw, 6rem) 0 3rem;
		overflow: clip;
	}

	.hero-glow {
		position: absolute;
		width: 540px;
		height: 540px;
		border-radius: 50%;
		top: -280px;
		right: -160px;
		background: radial-gradient(circle, rgba(47, 111, 150, 0.22) 0%, transparent 70%);
		pointer-events: none;
	}

	.hero-grid {
		display: grid;
		gap: 1.4rem;
	}

	.hero-copy {
		max-width: 760px;
	}

	h1,
	h2,
	h3 {
		font-family: 'Space Grotesk', 'Trebuchet MS', sans-serif;
		line-height: 1.08;
		letter-spacing: -0.02em;
		margin: 0;
	}

	h1 {
		font-size: clamp(2rem, 5.4vw, 3.65rem);
		max-width: 18ch;
		text-wrap: balance;
	}

	h2 {
		font-size: clamp(1.7rem, 4vw, 2.6rem);
		max-width: 18ch;
	}

	p,
	li,
	input,
	button,
	a,
	summary {
		font-family: 'Manrope', 'Segoe UI', sans-serif;
	}

	.eyebrow {
		color: var(--accent);
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.14em;
		margin: 0 0 0.65rem;
	}

	.lead {
		font-size: 1.05rem;
		line-height: 1.6;
		max-width: 56ch;
		color: var(--muted);
	}

	.hero-cta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8rem;
		margin: 1.6rem 0 1.1rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.8rem 1.2rem;
		border-radius: 999px;
		text-decoration: none;
		font-weight: 700;
		transition: transform 220ms ease, box-shadow 220ms ease, background-color 220ms ease;
	}

	.button-primary {
		background: var(--accent);
		color: #fff;
		border: none;
		box-shadow: 0 12px 22px rgba(47, 111, 150, 0.28);
	}

	.button-ghost {
		background: transparent;
		border: 1px solid var(--line);
		color: var(--ink);
	}

	.button:hover,
	.button:focus-visible {
		transform: translateY(-2px);
	}

	.hero-facts {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
		list-style: none;
		padding: 0;
		margin: 0;
	}

	.hero-facts li {
		background: rgba(255, 255, 255, 0.75);
		border: 1px solid var(--line);
		padding: 0.42rem 0.75rem;
		border-radius: 999px;
		font-size: 0.92rem;
	}

	.hero-panel {
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 22px;
		padding: 1.25rem;
		box-shadow: var(--shadow);
	}

	.hero-panel ul {
		margin: 1rem 0;
		padding: 0;
		list-style: none;
		display: grid;
		gap: 0.6rem;
	}

	.hero-panel li {
		padding-left: 1.2rem;
		position: relative;
	}

	.hero-panel li::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.55em;
		width: 0.55rem;
		height: 0.55rem;
		border-radius: 50%;
		background: var(--accent);
	}

	.panel-note {
		margin: 0;
		font-size: 0.92rem;
		color: var(--muted);
	}

	.section {
		padding: clamp(2.8rem, 5vw, 4.8rem) 0;
	}

	.section-soft {
		background: linear-gradient(0deg, var(--bg-soft), var(--bg-soft));
		border-top: 1px solid rgba(0, 0, 0, 0.02);
		border-bottom: 1px solid rgba(0, 0, 0, 0.02);
	}

	.section-head {
		margin-bottom: 1.3rem;
	}

	.card-grid {
		display: grid;
		gap: 0.95rem;
	}

	.card {
		padding: 1.1rem;
		border-radius: 18px;
		background: var(--paper);
		border: 1px solid var(--line);
		box-shadow: var(--shadow);
	}

	.steps {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 0.85rem;
	}

	.steps li {
		display: flex;
		align-items: flex-start;
		gap: 0.9rem;
		padding: 1rem;
		background: var(--paper);
		border: 1px solid var(--line);
		border-radius: 16px;
	}

	.steps span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
