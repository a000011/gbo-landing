					<p>г. Тольятти, ул. Ларина 145<br/>Пн-Пт: 09:00-19:00<br/>Сб: 09:00-13:00</p>
					<p><a href="tel:+79178102341">+7 (917) 810-23-41</a></p>
				<p><a href="tel:+79278988878">+7 (927) 899-88-78</a></p>					<div class="contact-socials" aria-label="Социальные сети">
						<a
							class="social-link social-link-vk"
							href="https://vk.com/gbotlt"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Группа Gas Trek во ВКонтакте"
